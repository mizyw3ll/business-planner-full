# ═══════════════════════════════════════════════════════════════
#  Скопируй как .env и заполни значения
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Domain ──────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ── PostgreSQL (docker-compose) ─────────────────────────────
# Эти значения задают пользователя и пароль в PostgreSQL.
# Они должны совпадать с APP_CONFIG__DB__URL ниже.
POSTGRES_DB=business_planner
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_strong_password

# ── Backend: DB Connection ──────────────────────────────────
APP_CONFIG__DB__URL=postgresql+asyncpg://your_user:your_strong_password@pg:5432/business_planner
APP_CONFIG__DB__ECHO=false

# ── Backend: Access Tokens ──────────────────────────────────
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
APP_CONFIG__ACCESS_TOKEN__RESET_PASSWORD_TOKEN_SECRET=your_hex_secret_here_64_chars
APP_CONFIG__ACCESS_TOKEN__VERIFICATION_TOKEN_SECRET=your_hex_secret_here_64_chars

# ── Backend: Email ──────────────────────────────────────────
APP_CONFIG__EMAIL__PROVIDER=smtp
APP_CONFIG__EMAIL__FROM_EMAIL=noreply@yourdomain.com
APP_CONFIG__EMAIL__FROM_NAME=Business Planner
APP_CONFIG__EMAIL__FRONTEND_URL=https://yourdomain.com

APP_CONFIG__EMAIL__SMTP_HOST=smtp.mail.ru
APP_CONFIG__EMAIL__SMTP_PORT=587
APP_CONFIG__EMAIL__SMTP_USER=your-email@mail.ru
APP_CONFIG__EMAIL__SMTP_PASSWORD=your-smtp-password
APP_CONFIG__EMAIL__SMTP_TLS=true

# ── Backend: CORS ───────────────────────────────────────────
APP_CONFIG__CORS__ALLOW_CREDENTIALS=true
APP_CONFIG__CORS__ALLOW_ORIGINS=["https://yourdomain.com","http://localhost:3000"]
APP_CONFIG__CORS__ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
APP_CONFIG__CORS__ALLOW_HEADERS=["Content-Type","Authorization"]

# ── Backend: AI (OpenRouter) ────────────────────────────────
APP_CONFIG__AI__PROVIDER=fullai
APP_CONFIG__AI__BASE_URL=https://openrouter.ai/api/v1
APP_CONFIG__AI__API_KEY=YOUR_OPENROUTER_KEY
APP_CONFIG__AI__MODEL=qwen/qwen3-8b
APP_CONFIG__AI__TIMEOUT_SECONDS=120
APP_CONFIG__AI__TEMPERATURE=0.2
APP_CONFIG__AI__MAX_TOKENS=1200
APP_CONFIG__AI__MAX_CHARS=5000

# ── Backend: Currency Sync ──────────────────────────────────
APP_CONFIG__CURRENCY_SYNC__ENABLED=true
APP_CONFIG__CURRENCY_SYNC__INTERVAL_MINUTES=60

# ── Backend: S3 Storage ────────────────────────────────────
APP_CONFIG__S3__ENABLED=true
APP_CONFIG__S3__ENDPOINT_URL=https://s3.cloud.ru
APP_CONFIG__S3__BUCKET=your-bucket-name
APP_CONFIG__S3__ACCESS_KEY=your-access-key
APP_CONFIG__S3__SECRET_KEY=your-secret-key
APP_CONFIG__S3__REGION=ru-central-1

# ── Backend: Server ────────────────────────────────────────
APP_CONFIG__RUN__HOST=0.0.0.0
APP_CONFIG__RUN__PORT=8000
